# ─────────────────────────────────────────────
#  CDN FITZ — Variáveis de Ambiente
# ─────────────────────────────────────────────

# Conexão com o PostgreSQL criado no EasyPanel.
# Pegue a string de conexão no painel do serviço de banco.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:senha@cdn-fitz-db:5432/cdn_fitz"

# Senha única de acesso ao site. Troque quando quiser — sem mexer no código.
APP_PASSWORD="cdn@2030"

# Chave secreta para assinar os cookies de sessão.
# Gere uma string longa e aleatória (mínimo 32 caracteres).
# Ex.: rode no terminal -> openssl rand -base64 32
AUTH_SECRET="troque-isto-por-uma-string-bem-longa-e-aleatoria"

# (Opcional) Diretório persistente onde os áudios são gravados.
# No EasyPanel, monte um volume e aponte para ele, ex.: /app/uploads
# Se não definir, usa /public/audios (NÃO persiste entre deploys!).
AUDIO_DIR="/app/uploads"
