// Prisma schema — banco de dados do CDN Fitz
// Usa PostgreSQL (criado no EasyPanel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Audio {
  id          String   @id @default(cuid())
  title       String
  fileName    String
  mimeType    String
  size        Int
  durationSec Int?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        Tag[]    @relation("AudioTags")

  @@index([createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#7C3AED")
  audios    Audio[]  @relation("AudioTags")
  createdAt DateTime @default(now())
}
