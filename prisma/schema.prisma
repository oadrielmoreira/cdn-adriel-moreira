// Prisma schema — banco de dados do CDN Fitz
// Usa PostgreSQL (criado no EasyPanel)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Audio {
  id          String   @id @default(cuid())
  title       String
  fileName    String // nome do arquivo salvo em /public/audios
  mimeType    String
  size        Int // tamanho em bytes
  durationSec Int? // duração em segundos (opcional)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relação muitos-para-muitos com Tag
  tags Tag[] @relation("AudioTags")

  @@index([createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())

  // relação muitos-para-muitos com Audio
  audios Audio[] @relation("AudioTags")
}
